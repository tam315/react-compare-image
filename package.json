{
  "name": "react-compare-image",
  "version": "3.5.18",
  "description": "React component to compare two images using slider.",
  "main": "./dist/ReactCompareImage.umd.js",
  "module": "./dist/ReactCompareImage.mjs",
  "types": "./dist/ReactCompareImage.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ReactCompareImage.d.ts",
      "require": "./dist/ReactCompareImage.umd.js",
      "import": "./dist/ReactCompareImage.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build && npm run test:dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest --browser.headless",
    "test:dist": "node scripts/smoke-test-dist.mjs",
    "test:ui": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "tam315/react-compare-image"
  },
  "author": "Shota Tamura",
  "license": "MIT",
  "peerDependencies": {
    "react": "^16.8 || ^17 || ^18 || ^19",
    "react-dom": "^16.8 || ^17 || ^18 || ^19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/resize-observer-browser": "^0.1.11",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "brace-expansion": "5.0.7",
